{
  "expo": {
    "name": "trackie",
    "slug": "trackie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/home_logo.png",
    "scheme": "trackiefrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karoldmejiaa.trackie",
      "infoPlist": {
        "NSCameraUsageDescription": "Esta aplicación necesita acceso a la cámara para tomar fotos de tus progresos de peso",
        "NSPhotoLibraryUsageDescription": "Esta aplicación necesita acceso a tu galería para seleccionar fotos de tus progresos de peso",
        "NSPhotoLibraryAddUsageDescription": "Esta aplicación necesita guardar fotos en tu galería"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/home_logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO"
      ],
      "package": "com.karoldmejiaa.trackie"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/home_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/home_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Esta aplicación necesita acceder a tus fotos para guardar tus progresos de peso.",
          "cameraPermission": "Esta aplicación necesita acceder a tu cámara para tomar fotos de tus progresos."
        }
      ],
      "react-native-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "342e4b76-a1ba-4aef-95a1-ce7c6760c7f6"
      }
    }
  }
}